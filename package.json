{
  "name": "oapi-bundler",
  "version": "0.1.1",
  "description": "OpenAPI tool for merging together multiple spec parts into one spec document",
  "author": {
    "name": "Piotr Dabrowski",
    "url": "https://github.com/yhnavein"
  },
  "license": "MIT",
  "homepage": "https://github.com/yhnavein/oapi-bundler",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yhnavein/oapi-bundler.git"
  },
  "bugs": {
    "url": "https://github.com/yhnavein/oapi-bundler/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "oapi-bundler": "dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "sucrase ./src -d ./dist --transforms typescript,imports && bun run rm-tests",
    "rm-tests": "find dist/ \\( -name '*.spec.js' -o -name 'types.js' \\) -type f -delete",
    "test": "bun test"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "openapi",
    "oapi",
    "spec",
    "openapi 3.0",
    "openapi 3.1",
    "openapi 3.2",
    "rest",
    "merge",
    "bundle"
  ],
  "dependencies": {
    "commander": "^14.0.3",
    "tinyglobby": "^0.2.15",
    "yaml": "^2.8.2",
    "picocolors": "1.1.1"
  },
  "devDependencies": {
    "bun-types": "1.3.10",
    "openapi-types": "^12.1.3",
    "sucrase": "3.35.1",
    "typescript": "5.9.3"
  }
}
